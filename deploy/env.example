# lark-bridge 环境变量示例
#
# 用法：
#   cp env.example .env
#   填入真实值
#   set -a; source .env; set +a
#
# 或用 systemd：
#   EnvironmentFile=/etc/lark-bridge/.env

# 飞书应用凭证（feishu-front 必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 前端与后端的 IPC 共享密钥（三者必须一致）
# 生成：openssl rand -hex 32
IPC_SECRET=change-me-to-a-random-64-char-hex-string

# IPC 监听地址与持久化目录（config 模板里 ${IPC_ADDR} / ${STATE_DIR} 展开）
# 这两项是部署参数：deploy.sh 每次部署都强制同步为本次运行值（覆盖 .env 中旧值），
# 所以这里的字面量仅为占位。想改请在运行 deploy.sh 前用环境变量覆盖：
#   IPC_ADDR=127.0.0.1:6060 STATE_DIR=/data/lark-bridge ./deploy/deploy.sh
IPC_ADDR=localhost:6060
STATE_DIR=/var/lib/lark-bridge

# 工作区根目录（claude-back / opencode-back 读取）
# /cd 弹出选择卡只列出此目录下的子目录，文本输入也限制在此范围内。
# 留空则 /cd 报「未配置」；不影响默认 per-chat 工作目录分配。
WORKSPACE_ROOT=/home/user/ZCodeProject
