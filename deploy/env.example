# lark-bridge 环境变量示例
#
# 用法：
#   cp env.example .env
#   填入真实值
#   set -a; source .env; set +a
#
# 或用 systemd：
#   EnvironmentFile=/etc/lark-bridge/.env

# 飞书应用凭证（feishu-front 必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 前端与后端的 IPC 共享密钥（三者必须一致）
# 生成：openssl rand -hex 32
IPC_SECRET=change-me-to-a-random-64-char-hex-string

# IPC 监听地址与持久化目录（config 模板里 ${IPC_ADDR} / ${STATE_DIR} 展开）
# 这两项是部署参数：deploy.sh 每次部署都把本次运行值同步进 repo 根 .env 的这两行
# （会覆盖 .env 里的字面量），所以这里的字面量仅为占位。想改请在运行 deploy.sh
# 前用环境变量覆盖：
#   IPC_ADDR=127.0.0.1:6060 STATE_DIR=/data/lark-bridge ./deploy/deploy.sh
# 注意：.env 其余键（凭证/MINIAGENT_*/WORKSPACE_ROOT 等）不被 deploy.sh 覆盖，
# 运维直接编辑 repo 根 .env，下次部署即生效（整文件覆盖到 CONFIG_DIR/.env）。
IPC_ADDR=localhost:6060
STATE_DIR=/var/lib/lark-bridge

# 日志级别（config 模板 ${LOG_LEVEL} 展开，全服务统一）
# 取值 debug/info/warn/error。缺省时 deploy.sh 自动补 info；改后重新部署生效。
LOG_LEVEL=info
# PROJECT_ROOT 由 deploy.sh 自动注入（repo 根路径），用于 deploy-monitor 的 project_root 展开。

# 前端 IPC 地址（backend 连前端用，config 模板 ${FRONTEND_URL} 展开）。
# 单机：deploy.sh 未设时自动推导为 http://$IPC_ADDR，无需手填。
# 多机：前端机保持默认；backend 机改为前端机可达地址，如 http://192.168.1.10:6060。
# 前端机要让 backend 跨机连入，IPC_ADDR 需监听非 loopback（如 0.0.0.0:6060）。
FRONTEND_URL=

# 工作区根目录（deploy.sh 自动推导为 PROJECT_ROOT 的上一级，通常无需手改）
# claude-back / opencode-back 的 /cd 弹出选择卡只列出此目录下的子目录。
# miniagent-back 的 read_file/write_file/shell 工具也以此作边界（security_level=default）。
# 如需指定其他路径，编辑 .env 里的 WORKSPACE_ROOT 后重新部署即可覆盖。
WORKSPACE_ROOT=

# miniagent-back（三项均必填，config.example.json 里以 ${VAR} 引用）
# MINIAGENT_API_KEY        OpenAI 兼容 endpoint 的 Bearer key
# MINIAGENT_BASE_URL       OpenAI 兼容根地址（无 /v1 后缀），如 https://api.openai.com
# MINIAGENT_DEFAULT_MODEL  请求里的 model 字段，如 gpt-4o-mini
MINIAGENT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIAGENT_BASE_URL=https://api.openai.com
MINIAGENT_DEFAULT_MODEL=gpt-4o-mini

# opencode-serve-back 连 opencode serve 的 Basic auth 密码（仅部署 opencode-serve 时必填）
# 用户名固定为 opencode；opencode serve 启动时读同名环境变量决定密码。
OPENCODE_SERVER_PASSWORD=opencode
