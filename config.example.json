{
  "feishu_app_id":     "${FEISHU_APP_ID}",
  "feishu_app_secret": "${FEISHU_APP_SECRET}",
  "feishu_domain":     "feishu",
  "feishu_log_level":  "info",

  "ipc_secret":   "${IPC_SECRET}",
  "ipc_addr":     "${IPC_ADDR}",
  "backend_id":   "claude-1",
  "frontend_url": "http://${IPC_ADDR}",

  "claude": {
    "cli_path":            "claude",
    "permission_mode":     "acceptEdits",
    "default_directory":   "${STATE_DIR}/claude",
    "max_concurrent":      4,
    "append_system_prompt": "你的回答应该简洁，通常不超过1000字",
    "stream_history":      50,
    "model_options":       ["haiku", "sonnet", "opus"],
    "permission_options":  ["acceptEdits", "plan", "bypassPermissions"],
    "effort_options":      ["low", "medium", "high", "xhigh", "max"],
    "settings_dir":        "~/.claude",
    "settings_cache_ttl":  3600
  },

  "opencode": {
    "cli_path":          "opencode",
    "default_directory": "${STATE_DIR}/opencode",
    "max_concurrent":    4,
    "stream_history":    50,
    "list_cache_ttl":    3600
  },

  "miniagent": {
    "api_key":         "${MINIAGENT_API_KEY}",
    "base_url":        "${MINIAGENT_BASE_URL}",
    "model":           "${MINIAGENT_DEFAULT_MODEL}",
    "system_prompt":   "你是一个飞书群里的 AI 助手，通过工具辅助用户完成编程和运维任务。\n\n行为准则：\n- 回答简洁直接，重点先行。代码用代码块，长输出用摘要而非全文粘贴。\n- 不确定文件内容时直接用工具读取，不要凭空猜测。\n- 能一步解决的不要拆成多步：读完文件直接给结论，不要先说\"我来读一下\"再等下一轮。\n- 执行有副作用的操作（写文件、跑命令）前，如果影响较大，先用一句话说明你将要做什么。\n- 遇到错误时说明原因并给出修复建议，不要反复重试相同操作。",
    "max_tokens":      4096,
    "workspace_root":  "${WORKSPACE_ROOT}",
    "memory_enabled":  true,
    "security_level":  "free"
  },

  "deploy_monitor": {
    "project_root":  "/home/user/ZCodeProject/lark-bridge",
    "deploy_target": "deploy"
  },

  "log_level":            "info",
  "log_output":           "stderr",
  "log_format":           "text",
  "log_debug_redact":     true,
  "component_log_levels": {},

  "state_dir": "${STATE_DIR}",

  "timeouts": {
    "backend_health":     "90s"
  },

  "dedup": {
    "stale_window":       "300s",
    "event_ttl":          "5m",
    "event_max_entries":  1000
  }
}
