{
  "feishu_app_id":     "${FEISHU_APP_ID}",
  "feishu_app_secret": "${FEISHU_APP_SECRET}",
  "feishu_domain":     "feishu",
  "feishu_log_level":  "info",

  "ipc_secret":   "${IPC_SECRET}",
  "ipc_addr":     "${IPC_ADDR}",
  "backend_id":   "claude-1",
  "frontend_url": "${FRONTEND_URL}",

  "claude": {
    "cli_path":            "claude",
    "permission_mode":     "acceptEdits",
    "default_directory":   "${STATE_DIR}/claude",
    "max_concurrent":      4,
    "append_system_prompt": "你的回答应该简洁，通常不超过1000字",
    "stream_history":      50,
    "model_options":       ["haiku", "sonnet", "opus"],
    "permission_options":  ["acceptEdits", "plan", "bypassPermissions"],
    "effort_options":      ["low", "medium", "high", "xhigh", "max"],
    "settings_dir":        "~/.claude",
    "settings_cache_ttl":  3600
  },

  "opencode": {
    "cli_path":          "opencode",
    "default_directory": "${STATE_DIR}/opencode",
    "max_concurrent":    4,
    "stream_history":    50,
    "list_cache_ttl":    3600
  },

  "opencode_serve": {
    "base_url":         "http://127.0.0.1:4096",
    "max_concurrent":   4
  },

  "miniagent": {
    "api_key":         "${MINIAGENT_API_KEY}",
    "base_url":        "${MINIAGENT_BASE_URL}",
    "model":           "${MINIAGENT_DEFAULT_MODEL}",
    "system_prompt":   "飞书群里有长期记忆的工程助手。工具：memory_set/get/list/delete，记忆分 chat/project/global。\n\n【首轮强制】memory_list prefix=meta.（拉项目沉淀的工作规范）+ memory_list scope=project，然后才回答。\n【主动沉淀，不等用户说记住】多步任务→set task.current=目标+步骤，每阶段更新；关键决策/根因→set decision.* 或 finding.* 写清为什么；项目稳定事实（架构/技术栈/构建测试命令/目录约定）→scope=project；用户偏好/身份/语言→scope=global。\n【scope 默认 project】仅本对话有意义用 chat；跨项目用 global。\n【key】小写英文点号：task.* decision.* finding.* project.* user.* env.*。value 一句话，禁中文 key。\n\n回答简洁重点先行；不确定先查（memory_get 或读文件）别猜；副作用操作前说明；遇错说原因和修复，别盲目重试。",
    "max_tokens":      4096,
    "stream":          false,
    "workspace_root":  "${WORKSPACE_ROOT}",
    "memory_enabled":  true,
    "permission":      "free",
    "shell_blocked_patterns": []
  },

  "deploy_monitor": {
    "project_root":  "${PROJECT_ROOT}",
    "deploy_target": "deploy"
  },

  "log_level":            "info",
  "log_output":           "stderr",
  "log_format":           "text",
  "log_debug_redact":     true,
  "component_log_levels": {},

  "state_dir": "${STATE_DIR}",

  "timeouts": {
    "backend_health":     "90s"
  },

  "dedup": {
    "stale_window":       "300s",
    "event_ttl":          "5m",
    "event_max_entries":  1000
  }
}
